---
import { siteConfig } from '../config/site';

const currentYear = new Date().getFullYear();
---

<footer class="bg-navy-deeper text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Bedrijfsinfo -->
      <div>
        <a href="/" class="inline-block mb-5">
          <img src="/images/logo_reversed.webp" alt="Zentura BV Logo" class="h-12 w-auto" />
        </a>
        <p class="text-gray-300 text-sm leading-relaxed mb-4">
          Snel, betrouwbaar en persoonlijk uitzendbureau voor fysiek en logistiek werk. Altijd personeel. Nooit excuses.
        </p>
        {siteConfig.kvk && (
          <p class="text-gray-500 text-xs">KvK: {siteConfig.kvk}</p>
        )}
        {siteConfig.btw && (
          <p class="text-gray-500 text-xs">BTW: {siteConfig.btw}</p>
        )}
      </div>

      <!-- Navigatie -->
      <div>
        <h3 class="font-heading font-semibold text-white mb-4 text-sm uppercase tracking-wider">Navigatie</h3>
        <ul class="space-y-2.5">
          {siteConfig.navigation.map((item) => (
            <li>
              <a href={item.href} class="text-gray-400 hover:text-primary transition-colors text-sm">
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-heading font-semibold text-white mb-4 text-sm uppercase tracking-wider">Contact & Spoed</h3>
        <ul class="space-y-3 text-sm">
          <li>
            <p class="text-gray-500 text-xs mb-1">Bussum</p>
            <a href={`tel:${siteConfig.phone.bussum}`} class="text-gray-300 hover:text-primary transition-colors flex items-center gap-2">
              <svg class="w-4 h-4 flex-shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              {siteConfig.phone.display_bussum}
            </a>
          </li>
          <li>
            <p class="text-gray-500 text-xs mb-1">Heerenveen</p>
            <a href={`tel:${siteConfig.phone.heerenveen}`} class="text-gray-300 hover:text-primary transition-colors flex items-center gap-2">
              <svg class="w-4 h-4 flex-shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              {siteConfig.phone.display_heerenveen}
            </a>
          </li>
          <li class="pt-1">
            <a href={`mailto:${siteConfig.email.sales}`} class="text-gray-400 hover:text-primary transition-colors flex items-center gap-2">
              <svg class="w-4 h-4 flex-shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              {siteConfig.email.sales}
            </a>
          </li>
          <li>
            <a href={`mailto:${siteConfig.email.spoed}`} class="text-gray-400 hover:text-primary transition-colors flex items-center gap-2">
              <svg class="w-4 h-4 flex-shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              {siteConfig.email.spoed}
            </a>
          </li>
        </ul>

        <div class="mt-5 pt-5 border-t border-gray-700/50">
          <p class="text-xs text-gray-500">24/7 bereikbaar voor spoedaanvragen</p>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-8 border-t border-gray-700/50 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs">
      <p class="text-gray-500">
        &copy; {currentYear} {siteConfig.name} — Alle rechten voorbehouden
      </p>
      <a
        href="https://jbrwebsolutions.nl"
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-600 hover:text-gray-400 transition-colors"
      >
        Website door JBr WebSolutions
      </a>
    </div>
  </div>
</footer>
