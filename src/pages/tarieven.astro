---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../config/site';

const title = 'Tarieven';
const description = 'Transparante uitzendtarieven van Zentura. Standaard €30/u, Spoed €40/u, Nacht & Weekend €45/u, Project €25/u. Geen verborgen kosten, 100% garantie.';

const inbegrepen = [
  'Voorselectie & screening van kandidaten',
  'Transport naar locatie (indien afgesproken)',
  'Persoonlijke begeleiding door Zentura',
  'Vervanging bij uitval op dezelfde dag',
  'Administratieve afhandeling',
  'Volledige aansprakelijkheidsdekking',
];
---

<Layout title={title} description={description}>

  <!-- ═══ PAGE HERO ═══ -->
  <section class="relative py-16 sm:py-24 overflow-hidden" style="background-color: #161d30; border-bottom: 4px solid #fe7303;">
    <!-- Watermark -->
    <div class="absolute inset-0 flex items-center overflow-hidden pointer-events-none select-none" aria-hidden="true">
      <span class="font-heading font-black text-white leading-none" style="font-size: clamp(80px, 18vw, 180px); opacity: 0.04; white-space: nowrap; padding-left: 1rem;">PRIJS</span>
    </div>
    <div class="container-custom relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Links: heading -->
        <div class="border-l-4 border-primary pl-6">
          <p class="text-primary text-xs font-bold uppercase tracking-widest mb-3">Zentura — Eerlijk en transparant</p>
          <h1 class="font-heading text-5xl sm:text-6xl font-black text-white leading-tight">
            Tarieven
          </h1>
          <p class="text-gray-400 text-lg mt-4 leading-relaxed">
            Geen kleine lettertjes. Geen verrassingen achteraf. U weet vooraf precies wat personeel kost.
          </p>
        </div>
        <!-- Rechts: snelle tarief-rijen -->
        <div class="hidden lg:flex flex-col divide-y divide-white/10 border border-white/10">
          {siteConfig.tarieven.map((t) => (
            <div class:list={[
              "flex items-center justify-between px-6 py-4",
              t.kleur === 'oranje' ? "bg-primary" : "bg-white/5"
            ]}>
              <div>
                <p class:list={["font-heading font-black text-sm", t.kleur === 'oranje' ? "text-white" : "text-white"]}>{t.naam}</p>
                <p class:list={["text-xs mt-0.5", t.kleur === 'oranje' ? "text-white/70" : "text-gray-500"]}>{t.voor}</p>
              </div>
              <span class:list={["font-heading font-black text-xl flex-shrink-0 ml-4", t.kleur === 'oranje' ? "text-white" : "text-primary"]}>{t.prijs}<span class="text-xs font-normal ml-1 opacity-60">/u</span></span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TARIEFKAARTEN ═══ -->
  <section class="section-padding bg-cream bg-grid-light">
    <div class="container-custom">

      <div class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-1 bg-primary flex-shrink-0"></div>
          <span class="text-primary text-xs font-bold tracking-widest uppercase">Kies uw tarief</span>
        </div>
        <h2 class="font-heading text-3xl sm:text-4xl font-black text-navy">
          Vier duidelijke tarieven
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {siteConfig.tarieven.map((tarief) => (
          <div class:list={[
            "relative border-2 flex flex-col",
            tarief.kleur === 'oranje'
              ? "bg-primary border-primary"
              : tarief.kleur === 'navy'
              ? "bg-navy border-navy"
              : "bg-white border-gray-200 hover:border-primary transition-colors"
          ]}>

            {tarief.badge && (
              <div class:list={[
                "px-4 py-2 text-xs font-black uppercase tracking-widest text-center",
                tarief.kleur === 'oranje' ? "bg-white/15 text-white" : "bg-primary text-white"
              ]}>
                {tarief.badge}
              </div>
            )}

            <div class="p-7 flex flex-col flex-1">
              <p class:list={[
                "text-xs font-bold uppercase tracking-widest mb-4",
                tarief.kleur !== 'wit' ? "text-white/60" : "text-gray-400"
              ]}>
                {tarief.naam}
              </p>

              <!-- Prijs groot -->
              <div class="mb-4">
                <div class="flex items-baseline gap-1 mb-1">
                  <span class:list={[
                    "font-heading text-5xl font-black leading-none",
                    tarief.kleur === 'oranje' ? "text-white" : tarief.kleur === 'navy' ? "text-white" : "text-primary"
                  ]}>
                    {tarief.prijs}
                  </span>
                  <span class:list={["text-sm font-medium", tarief.kleur !== 'wit' ? "text-white/60" : "text-gray-500"]}>
                    {tarief.per}
                  </span>
                </div>
                <p class:list={["text-sm leading-relaxed", tarief.kleur !== 'wit' ? "text-white/80" : "text-gray-600"]}>
                  {tarief.description}
                </p>
              </div>

              <!-- Details -->
              <div class:list={[
                "space-y-2.5 text-xs flex-1 border-t pt-5 mt-2",
                tarief.kleur !== 'wit' ? "border-white/10" : "border-gray-100"
              ]}>
                <div class:list={["flex items-start gap-2", tarief.kleur !== 'wit' ? "text-white/55" : "text-gray-500"]}>
                  <span class="font-semibold text-xs uppercase tracking-wider w-24 flex-shrink-0">Min. afname</span>
                  <span>{tarief.min_uren}</span>
                </div>
                <div class:list={["flex items-start gap-2", tarief.kleur !== 'wit' ? "text-white/55" : "text-gray-500"]}>
                  <span class="font-semibold text-xs uppercase tracking-wider w-24 flex-shrink-0">Opzegging</span>
                  <span>{tarief.opzegtermijn}</span>
                </div>
                <div class:list={[
                  "pt-3 border-t text-xs leading-relaxed",
                  tarief.kleur !== 'wit' ? "border-white/8 text-white/50" : "border-gray-100 text-gray-400"
                ]}>
                  {tarief.voor}
                </div>
              </div>

              <!-- CTA knop -->
              <a
                href="/contact/"
                class:list={[
                  "mt-6 block text-center px-4 py-3 text-sm font-bold transition-colors",
                  tarief.kleur === 'oranje' ? "bg-white text-primary hover:bg-gray-50"
                  : tarief.kleur === 'navy' ? "bg-primary text-white hover:bg-primary-dark"
                  : "bg-navy text-white hover:bg-navy/80"
                ]}
              >
                Aanvragen
              </a>
            </div>
          </div>
        ))}
      </div>

      <p class="text-center text-gray-400 text-xs mt-8">
        Alle tarieven zijn exclusief BTW. Maatwerk tarieven bij grote volumes op aanvraag.
      </p>
    </div>
  </section>

  <!-- ═══ WAT ZIT ER ALTIJD BIJ ═══ -->
  <section class="section-padding bg-white">
    <div class="container-custom">

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-1 bg-primary flex-shrink-0"></div>
            <span class="text-primary text-xs font-bold tracking-widest uppercase">Altijd inbegrepen</span>
          </div>
          <h2 class="font-heading text-3xl font-black text-navy mb-4">
            Meer dan alleen een medewerker
          </h2>
          <p class="text-gray-600 text-base leading-relaxed mb-6">
            Bij elk tarief levert Zentura een complete service. Geen losse uren, maar een volledig ontzorgde inzet van start tot einde.
          </p>
          <a href="/contact/" class="inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-primary hover:bg-primary-dark text-white font-bold text-sm transition-colors">
            Aanvraag starten
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {inbegrepen.map((item) => (
            <div class="flex items-start gap-3 p-4 border-l-4 border-primary bg-cream">
              <svg class="w-4 h-4 text-primary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-gray-700 text-sm leading-relaxed font-medium">{item}</span>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ GARANTIE BALK ═══ -->
  <section class="py-16 border-t-4 border-primary" style="background-color: #052771;">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">

        <div>
          <div class="w-12 h-1 bg-primary mb-5"></div>
          <h2 class="font-heading text-3xl font-black text-white mb-3">100% tevredenheidsgarantie</h2>
          <p class="text-blue-200/75 text-base leading-relaxed">
            Niet tevreden over de geleverde medewerker? Meld het binnen 2 uur. Wij zorgen dezelfde dag voor vervanging. Betaalt u niet? Dan hebben wij onze afspraak niet nagekomen. Zentura staat achter elke plaatsing.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact/" class="inline-flex items-center justify-center gap-2 px-7 py-4 bg-primary hover:bg-primary-dark text-white font-bold text-sm transition-colors">
            Aanvraag indienen
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
          <a href={`tel:${siteConfig.phone.bussum}`} class="inline-flex items-center justify-center gap-2 px-7 py-4 border-2 border-white/25 hover:border-white/60 text-white font-semibold text-sm transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            Bel {siteConfig.phone.display_bussum}
          </a>
        </div>

      </div>
    </div>
  </section>

</Layout>
