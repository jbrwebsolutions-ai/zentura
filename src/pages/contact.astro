---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import { siteConfig } from '../config/site';

const title = 'Personeel aanvragen';
const description = 'Vraag snel personeel aan via Zentura. Bel +31 6 177 526 44 (Bussum) of +31 6 137 737 24 (Heerenveen). 24/7 bereikbaar voor spoedaanvragen.';
---

<Layout title={title} description={description}>

  <!-- ═══ PAGE HERO ═══ -->
  <section class="relative py-16 sm:py-24 overflow-hidden" style="background-color: #161d30; border-bottom: 4px solid #fe7303;">
    <!-- Watermark -->
    <div class="absolute inset-0 flex items-center overflow-hidden pointer-events-none select-none" aria-hidden="true">
      <span class="font-heading font-black text-white leading-none" style="font-size: clamp(80px, 20vw, 200px); opacity: 0.04; white-space: nowrap; padding-left: 1rem;">SPOED</span>
    </div>
    <div class="container-custom relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Links: heading -->
        <div class="border-l-4 border-primary pl-6">
          <p class="text-primary text-xs font-bold uppercase tracking-widest mb-3">Zentura — Snel schakelen</p>
          <h1 class="font-heading text-5xl sm:text-6xl font-black text-white leading-tight">
            Personeel aanvragen
          </h1>
          <p class="text-gray-400 text-lg mt-4 leading-relaxed">
            Stuur een aanvraag of bel direct. Bij spoed zijn we er binnen 5 minuten met een reactie.
          </p>
        </div>
        <!-- Rechts: directe telefoonnummers -->
        <div class="hidden lg:flex flex-col gap-3">
          <a href={`tel:${siteConfig.phone.bussum}`}
            class="group flex items-center gap-4 bg-primary hover:bg-primary-dark px-6 py-5 transition-colors">
            <svg class="w-6 h-6 text-white flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <div>
              <p class="text-white/70 text-xs font-bold uppercase tracking-wider">Bussum, Noord Holland</p>
              <p class="font-heading font-black text-white text-2xl">{siteConfig.phone.display_bussum}</p>
            </div>
          </a>
          <a href={`tel:${siteConfig.phone.heerenveen}`}
            class="group flex items-center gap-4 bg-white/5 hover:bg-white/10 border border-white/15 px-6 py-5 transition-colors">
            <svg class="w-6 h-6 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <div>
              <p class="text-white/50 text-xs font-bold uppercase tracking-wider">Heerenveen, Friesland</p>
              <p class="font-heading font-black text-white text-2xl">{siteConfig.phone.display_heerenveen}</p>
            </div>
          </a>
          <p class="text-gray-500 text-xs px-1">24/7 bereikbaar voor spoedaanvragen</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TELEFOONNUMMERS PROMINENT ═══ -->
  <div style="background-color: #052771;">
    <div class="container-custom">
      <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-white/10">

        <a
          href={`tel:${siteConfig.phone.bussum}`}
          class="group flex items-center gap-5 py-8 px-6 hover:bg-white/5 transition-colors"
        >
          <div class="w-14 h-14 bg-primary flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <div>
            <p class="text-white/60 text-xs font-bold uppercase tracking-wider">Bussum — 24/7 spoed</p>
            <p class="font-heading font-black text-white text-2xl sm:text-3xl group-hover:text-primary transition-colors">{siteConfig.phone.display_bussum}</p>
          </div>
        </a>

        <a
          href={`tel:${siteConfig.phone.heerenveen}`}
          class="group flex items-center gap-5 py-8 px-6 hover:bg-white/5 transition-colors"
        >
          <div class="w-14 h-14 bg-white/10 group-hover:bg-primary flex items-center justify-center flex-shrink-0 transition-colors">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <div>
            <p class="text-white/60 text-xs font-bold uppercase tracking-wider">Heerenveen — 24/7 spoed</p>
            <p class="font-heading font-black text-white text-2xl sm:text-3xl group-hover:text-primary transition-colors">{siteConfig.phone.display_heerenveen}</p>
          </div>
        </a>

      </div>
    </div>
  </div>

  <!-- ═══ FORMULIER + SIDEBAR ═══ -->
  <section class="section-padding bg-cream bg-grid-light">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        <!-- Formulier (2/3) -->
        <div class="lg:col-span-2">
          <div class="bg-white border-2 border-gray-100 p-8 sm:p-10">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-1 bg-primary flex-shrink-0"></div>
              <span class="text-primary text-xs font-bold tracking-widest uppercase">Aanvraagformulier</span>
            </div>
            <h2 class="font-heading text-2xl font-black text-navy mb-2">Personeel aanvragen</h2>
            <p class="text-gray-500 text-sm mb-8">We nemen dezelfde dag nog contact op. Bij spoed binnen 5 minuten.</p>
            <ContactForm />
          </div>
        </div>

        <!-- Sidebar (1/3) -->
        <div class="space-y-5">

          <!-- Bereikbaarheid -->
          <div class="bg-white border-2 border-gray-100">
            <div class="border-l-4 border-primary px-6 py-4 bg-cream">
              <h3 class="font-heading font-black text-navy text-sm">Bereikbaarheid</h3>
            </div>
            <div class="p-6 space-y-0">
              <div class="flex justify-between items-center py-3.5 border-b border-gray-50">
                <span class="text-gray-500 text-sm">Kantoor (ma–vr)</span>
                <span class="text-navy font-bold text-sm">08:00 – 18:00</span>
              </div>
              <div class="flex justify-between items-center py-3.5 border-b border-gray-50">
                <span class="text-gray-500 text-sm">Spoed (alle dagen)</span>
                <span class="text-primary font-bold text-sm">24/7</span>
              </div>
              <div class="flex justify-between items-center py-3.5">
                <span class="text-gray-500 text-sm">Reactietijd spoed</span>
                <span class="text-navy font-bold text-sm">&lt; 5 min</span>
              </div>
            </div>
          </div>

          <!-- Waarom Zentura -->
          <div class="bg-white border-2 border-gray-100">
            <div class="border-l-4 border-primary px-6 py-4 bg-cream">
              <h3 class="font-heading font-black text-navy text-sm">Waarom Zentura?</h3>
            </div>
            <ul class="p-6 space-y-3">
              {[
                'Bevestiging binnen 5 minuten',
                'Op locatie binnen 60 minuten',
                '24/7 bereikbaar voor spoed',
                '100% tevredenheidsgarantie',
                'Pre-gescreende kandidaten',
                'Vast aanspreekpunt',
              ].map((item) => (
                <li class="flex items-center gap-3 text-sm text-gray-600">
                  <svg class="w-4 h-4 text-primary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <!-- Email -->
          <div class="bg-white border-2 border-gray-100">
            <div class="border-l-4 border-primary px-6 py-4 bg-cream">
              <h3 class="font-heading font-black text-navy text-sm">E-mail</h3>
            </div>
            <div class="p-6 space-y-3">
              <a
                href={`mailto:${siteConfig.email.sales}`}
                class="flex items-center gap-3 group"
              >
                <svg class="w-4 h-4 text-gray-400 group-hover:text-primary transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                <div>
                  <p class="text-xs text-gray-400 font-bold uppercase tracking-wider">Verkoop</p>
                  <p class="text-navy text-sm font-medium group-hover:text-primary transition-colors">{siteConfig.email.sales}</p>
                </div>
              </a>
              <a
                href={`mailto:${siteConfig.email.spoed}`}
                class="flex items-center gap-3 group"
              >
                <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
                <div>
                  <p class="text-xs text-primary font-bold uppercase tracking-wider">Spoed e-mail</p>
                  <p class="text-navy text-sm font-medium group-hover:text-primary transition-colors">{siteConfig.email.spoed}</p>
                </div>
              </a>
            </div>
          </div>

          <!-- Vestigingen -->
          <div class="bg-white border-2 border-gray-100">
            <div class="border-l-4 border-primary px-6 py-4 bg-cream">
              <h3 class="font-heading font-black text-navy text-sm">Vestigingen</h3>
            </div>
            <div class="p-6 space-y-4">
              {siteConfig.addresses.map((a) => (
                <div>
                  <p class="font-bold text-navy text-xs uppercase tracking-wider">{a.label}</p>
                  <p class="text-gray-500 text-sm mt-0.5">{a.street}, {a.city}</p>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

</Layout>
